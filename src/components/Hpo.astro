---
import GeckoChart from '../components/GeckoChart.astro'
---

<landing>
  <script src='/src/scripts/hpo-data.js'></script>

  <div class='from-darkblue1 to-darkblue2 mx-auto min-w-90 bg-radial bg-fixed py-4 text-center'>
    <div class='mx-auto flex min-w-90 flex-row items-center text-center sm:max-w-5xl'>
      <div class='mb-16 w-full px-4 text-4xl font-bold sm:text-5xl'>
        <span class='from-purple1 to-pink1 bg-linear-to-r bg-clip-text text-transparent'>$HPO</span>, the Governance &
        Profit-Sharing Token of Hipo
      </div>
    </div>

    <div class='mx-auto mb-24 flex w-full flex-col items-center justify-between gap-4 px-4 sm:max-w-5xl md:flex-row'>
      <div class='lex flex-col justify-center gap-4 p-4 md:w-4/12'>
        <div class='mb-12 text-left text-3xl leading-relaxed font-medium'>
          Be Part of the
          <div class='bg-brush inline-block bg-contain bg-bottom bg-no-repeat whitespace-nowrap'>
            Future of GRAM Staking!
          </div>
        </div>

        <div class='min-w-70 md:px-8'>
          <a
            class='from-purple1 to-purple2 flex w-full flex-row place-content-center items-center gap-4 rounded-2xl bg-radial px-12 py-4'
            href='https://app.ston.fi/swap?chartVisible=false&ft=TON&tt=HPO'
            target='_blank'
            rel='noopener noreferrer'
          >
            <div class='text-2xl font-bold'>Buy HPO</div>
          </a>
        </div>
      </div>
      <div class='flex w-3/4 flex-row md:w-3/12 md:flex-col'>
        <div class='mb-10 flex w-full flex-row justify-start'>
          <img src='/images/hpo.svg' class='ml-4 size-20 -rotate-30' alt='HPO Token' />
        </div>
        <div class='mt-10 flex w-full flex-row justify-end'>
          <img src='/images/hpo.svg' class='mr-4 size-20 rotate-30' alt='HPO Token' />
        </div>
      </div>

      <div class='mx-auto w-full md:w-5/12'>
        <div class='flex flex-auto flex-col items-center'>
          <div class='mb-4 w-full'>
            <GeckoChart coin='hipo-governance-token' />
          </div>

          <div class='flex w-full flex-row justify-between text-sm'>
            <div class='flax-auto space-x-1'>
              <span class='text-lg font-normal'>Market Cap.: </span>
              <span id='hpoMarketCap' class='text-2xl font-bold'> </span>
            </div>
            <div class='flax-auto space-x-1'>
              <span class='text-lg font-normal'>Volume: </span>
              <span id='hpoVolume' class='text-2xl font-bold'> </span>
            </div>
            <div class='flax-auto space-x-1'>
              <span class='text-lg font-normal'>Holders: </span>
              <span id='hpoHolders' class='text-2xl font-bold'> </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class='mx-auto flex min-w-90 flex-col items-center sm:max-w-5xl'>
      <div class='mb-12 flex w-full flex-col items-center p-5'>
        <iframe
          class='aspect-video h-full w-full rounded-md'
          src='https://www.youtube.com/embed/QYU-TWJK1yg'
          title='YouTube video player'
          allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture'
          allowfullscreen></iframe>
      </div>

      <div class='mb-8 w-full px-4 text-2xl'>
        <div class='mb-12 font-bold'>Build Success With Our Community Through $HPO</div>
        <div class='mx-auto mb-4 max-w-md'>
