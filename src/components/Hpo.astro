              </li>
              <li class='border-purple3 border-opacity-25 border-t py-4'>
                <span class='font-bold text-white'>1.1M</span>
                <span class='text-white'>Telegram Subscribers</span>
              </li>
              <li class='border-purple3 border-opacity-25 border-t py-4'>
                <span class='font-bold text-white'>147K</span>
                <span class='text-white'>YouTube Subscribers</span>
              </li>
              <li class='border-purple3 border-opacity-25 border-t py-4'>
                <span class='font-bold text-white'>146K</span>
