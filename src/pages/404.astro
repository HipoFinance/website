---
import "../styles/global.css";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
  </head>

  <body class="bg-darkblue2 font-poppins text-gray1">
    <div
      class="mx-auto min-w-90 max-w-md bg-fixed py-4 text-center md:py-8 lg:py-16"
    >
      <div class="mb-4 text-7xl font-bold">404</div>

      <h1 class="mb-2 text-xl font-semibold">Page not found</h1>

      <p class="mb-6 text-white/60">
        The page you’re looking for doesn’t exist or has been moved.
      </p>

      <div class="mx-auto rounded-2xl border border-white/10 bg-white/5 p-4">
        <p class="mb-2 text-sm text-white/70">Need support?</p>
        <a
          href="https://t.me/hipo_chat"
          target="_blank"
          rel="noreferrer"
          class="text-sm text-indigo-400 hover:text-indigo-300"
        >
          Hipo Chat
        </a>
      </div>
    </div>
  </body>
</html>
